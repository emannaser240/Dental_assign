# ============================================
# IOU Score
# ============================================


def iou_score(outputs, targets, threshold=0.5):

    probs = torch.sigmoid(outputs)
    preds = (probs > threshold).float()

    preds = preds.view(-1)
    targets = targets.view(-1)

    intersection = (preds * targets).sum().item()

    union = (
        preds.sum().item()
        + targets.sum().item()
        - intersection
    )

    if union == 0:
        return 1.0

    return intersection / union

