# ============================================
# Combined Loss
# ============================================

def combined_loss(outputs, targets):

    bce = bce_loss(outputs, targets)

    dice = dice_loss(outputs, targets)

    return BCE_WEIGHT * bce + DICE_WEIGHT * dice

