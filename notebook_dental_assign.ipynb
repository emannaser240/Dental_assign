# ============================================
# Dice Score
# ============================================


def dice_score(outputs, targets):

    probs = torch.sigmoid(outputs)

    probs = probs.view(-1)
    targets = targets.view(-1)

    intersection = (probs * targets).sum()

    dice = (
        2 * intersection + 1e-8
    ) / (
        probs.sum() + targets.sum() + 1e-8
    )

    return dice.item()

